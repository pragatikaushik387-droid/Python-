# 1. Creating a AddCustomer function
def AddCustomer():
    file = open("customer.bin",'ab')
    Cid = input("Enter Customer ID:")
    Cname = input("Enter Customer Name:")
    Cadd = input("Enter Customer Add:")
    Cmob = input("Enter Customer Mob:")

    pickle.dump(Cid,file)   # dump/write data in file
    pickle.dump(Cname,file)
    pickle.dump(Cadd,file)
    pickle.dump(Cmob,file)

    print("Customer Add Successfully")
    input("Press Enter to be continue...")
    
        
    file.close()




