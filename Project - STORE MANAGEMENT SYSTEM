# 6. Creating a uppro function.
def uppro():
    file1 = open("product.bin",'rb')
    file2 = open("temp_.bin",'ab')
    Pid = input("Enter Product Id for update:")
    try:
        while True:
            data = pickle.load(file1)
            if Pid == data:
                pickle.dump(data,file2)
                
                name = pickle.load(file1)
                print("Current Name:", name)
                pickle.dump(name,file2)
                
                pickle.load(file1)   # price padhega
                price = input("Enter New Price for Update:")
                pickle.dump(price,file2)
                
                desc = pickle.load(file1) # desc of product
                pickle.dump(desc,file2)
                
            else:
                pickle.dump(data,file2)
    except:
        pass
    
    file1.close()
