#8. Write a function to return second largest number from a list.
def sec_larg(lst):
    largest = max(lst)
    second = float('-inf')
    for i in lst:
        if i< largest and i > second:
            second = i
    return second

print("Second largest number is :",sec_larg([1,88,9,66,96,200]))
    
    
    

#9. Write a function to remove duplicates from a list.
def remove_dup(lst):
    unique = []
    for i in lst:
        if i not in unique:
            unique.append(i)
    return unique
    
print("unique list is:",remove_dup([1,2,2,3,5,3,1,89]))


#10. Write a function to calculate Fibonacci series.
def fibbo(num):
    fib_series = []
    if num >= 1:
        fib_series.append(0)
    if num >= 2:
        fib_series.append(1)
        
    for i in range(2,num):
        next_term = fib_series[-1] + fib_series[-2]
        fib_series.append(next_term)
    return fib_series


print("Fibbonacci series is:",fibbo(5))


