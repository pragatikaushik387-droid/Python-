11. Write a recursive function for factorial.
def factorial(n):
    if n == 0 or n == 1:
        return 1
    else:
        return n * factorial(n-1)

print("Factorial is :",factorial(5))




#12. Write a function to check prime number.
def check_prime(num):
    
    if num <= 1:
        return False
    for i in range(2,num-1):
        if num % i == 0:
            return False
    return True
        

print(check_prime(21))
print(check_prime(17))

#13. Write a function to find GCD of two numbers.
def gcd(a,b):
    min_val = min(a,b)
    for i in range(1,min_val+1):
        if a % i == 0 and b % i == 0:
            gcd = i
    return gcd
print(gcd(24,36))
print(gcd(12,18))
            



#14. Write a function to count frequency of characters in a string.
